# ---------------------------------------------------------------------------
# UniversalAutoApplier - local-first configuration
#
# Copy this file to `.env` and edit values for your machine.
# `.env` is gitignored. Never commit real credentials or absolute paths
# that point at private data.
#
# All settings can also be provided as real environment variables, which take
# precedence over this file.
# ---------------------------------------------------------------------------

# Bind the local API/dashboard to localhost only. Do NOT change to 0.0.0.0
# unless you have added authentication first. See DEPLOYMENT_AND_REPO_STRATEGY.md.
UAA_HOST=127.0.0.1
UAA_PORT=8000

# Absolute path to a local data directory owned by UniversalAutoApplier.
# Queue, history database, logs, screenshots, traces, and artifacts live here.
UAA_DATA_DIR=./.uaa_data

# Absolute path to the JobHunter export file (application_queue.jsonl).
# Optional: if unset, the JobHunter queue is reported as `not_configured` in
# system health, but the dashboard still runs.
UAA_JOBHUNTER_QUEUE=

# Absolute path to the SiemensAutoApplier repository. Optional. If unset, the
# Siemens adapter is reported as `not_configured` in system health.
UAA_SIEMENS_REPO=

# Browser headless flag. Headed mode is the local default; headless is the test
# default. Set to `true` only when you do not need to observe the browser.
UAA_BROWSER_HEADLESS=false

# Optional persistent Playwright profile. UAA stores login cookies here so
# later live dry-runs can reuse an authenticated session. Keep this local and
# gitignored. If unset, the CLI uses UAA_DATA_DIR/browser-profile.
UAA_BROWSER_PROFILE_DIR=

# Optional installed browser channel (for example: chrome or msedge). Leave
# empty to use Playwright's bundled Chromium.
UAA_BROWSER_CHANNEL=
UAA_BROWSER_TIMEOUT_MS=30000
UAA_BROWSER_MAX_STEPS=20

# Submission mode. Safe defaults are `dry_run` and `review`. The mode
# `trusted_auto_submit` is dangerous and must never be the default for generic
# adapters. See IMPLEMENTATION_RULES.md -> Safety Rules for Submit.
UAA_SUBMIT_MODE=review

# ---------------------------------------------------------------------------
# LLM question resolution (Gemma)
#
# When the live browser executor encounters a form question that
# deterministic mapping cannot answer, a grounded LLM service (backed by
# Google/Gemma) may propose an answer using candidate evidence.
#
# The service may compose answers and infer from documented evidence, but
# it must never invent personal facts. Final submission remains blocked.
# High-risk categories (salary, legal, demographic, consent) always
# require human confirmation even if the LLM proposes an answer.
# ---------------------------------------------------------------------------

# Provider: "gemma" (default, uses google-genai SDK) or "mock" (for tests).
UAA_LLM_PROVIDER=gemma

# Google AI API key. If unset, the LLM service is "not_configured" and
# the executor creates an intervention for unresolved questions.
# Supports multiple keys via GOOGLE_AI_API_KEY, GOOGLE_AI_API_KEY2, etc.
# (same pattern as JobHunter). Set UAA_LLM_API_KEY to the primary key.
UAA_LLM_API_KEY=

# Model identifier. Defaults to JobHunter's primary Google model.
UAA_LLM_MODEL=gemma-4-26b-a4b-it

# Comma-separated fallback models (tried in order if the primary fails).
UAA_LLM_FALLBACK_MODELS=gemma-4-31b-it

# Request timeout in milliseconds.
UAA_LLM_TIMEOUT_MS=30000

# Retry count on transient failures (quota, timeout, 500s).
UAA_LLM_RETRY_COUNT=2

# Minimum confidence for auto-fill without human confirmation.
# Below this threshold, the answer requires user confirmation.
UAA_LLM_MIN_AUTO_FILL_CONFIDENCE=0.8
